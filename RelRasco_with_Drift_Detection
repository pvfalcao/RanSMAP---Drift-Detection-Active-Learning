#Model
clf = RelRasco()

#Variable for counting features
counter = 0

#Drift detector
for i in range(X_train.shape[1]):
    feature_idx = i
    alpha = 0.01
    # Define and fit detector
    detector = KSTest()

    X_train_numeric = pd.to_numeric(X_train[:, feature_idx], errors='coerce').reshape(-1, 1)
    __ = detector.fit(X_train_numeric)
    # Convert the feature column to numeric before comparing
    X_test_numeric = pd.to_numeric(X_test[:, feature_idx], errors='coerce').reshape(-1, 1)
    result, _ = detector.compare(X_test_numeric)

    # Check if drift is taking place
    if result.p_value <= alpha:
            counter += 1

if counter>(X_train.shape[1]/2):
        print(f"More than half of features had data drift detected. Actually the count is {counter}")

        
        np.random.seed(42)

        # Number of samples to add
        n_add = int(0.2 * len(X_test))

        # Random indices
        indices = np.random.choice(len(X_test), size=n_add, replace=False)

        # Samples to add
        X_add = X_test[indices]
        y_add = y_test[indices]

        # Add to training set
        X_train = np.concatenate([X_train, X_add], axis=0)
        y_train = np.concatenate([y_train, y_add], axis=0)

        # Remove from test set
        X_test = np.delete(X_test, indices, axis=0)
        y_test = np.delete(y_test, indices, axis=0)
        print("Datasets updated")
        

for lr in [0.1, 0.2, 0.3, 0.4]:

    X_ss, y_ss, X_unl, y_unl = artificial_ssl_dataset(X_train, y_train, lr)
    clf.fit(X_ss, y_ss)

        # Unlabeled score
    print(f"[LR={lr}] Unlabeled score: {clf.score(X_unl, y_unl):.4f}")




    y_pred = clf.predict(X_test)

    accuracy = accuracy_score(y_test, y_pred)
    precision = precision_score(y_test, y_pred, average='weighted')
    recall = recall_score(y_test, y_pred, average='weighted')
    f1 = f1_score(y_test, y_pred, average='weighted')

    print(f"Accuracy: {accuracy:.4f}")
    print(f"Precision (weighted): {precision:.4f}")
    print(f"Recall (weighted): {recall:.4f}")
    print(f"F1-score (weighted): {f1:.4f}")
    print("\nClassification Report:\n", classification_report(y_test, y_pred))